# ==============================================================================
# NDI Streamer Configuration
# Copy to .env and edit. Never commit .env to version control.
# ==============================================================================

# --- Database -----------------------------------------------------------------
# SQLite (default):
DATABASE_URL=sqlite:///ndi_streamer.db
# PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/ndi_streamer

# --- Flask --------------------------------------------------------------------
SECRET_KEY=change-me-in-production
FLASK_ENV=development
FLASK_PORT=5000

# --- NDI Defaults -------------------------------------------------------------
NDI_HOSTNAME=NDI-STREAMER
NDI_OUTPUT_FPS=60

# --- Browser Recycling --------------------------------------------------------
# Hours between full Chromium restarts per instance (prevents memory leaks)
BROWSER_RECYCLE_HOURS=4

# --- Uploads ------------------------------------------------------------------
UPLOAD_FOLDER=app/uploads
MAX_UPLOAD_SIZE_MB=50

# --- Logging / Syslog ---------------------------------------------------------
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable syslog forwarding (true/false)
SYSLOG_ENABLED=false

# Syslog target — local socket or remote host
# Local:  /dev/log  (Linux only)
# Remote: host:port (e.g. 192.168.1.100:514)
# Windows: use a remote address or leave SYSLOG_ENABLED=false
SYSLOG_ADDRESS=/dev/log

# Syslog facility (local0-local7, user, daemon, etc.)
SYSLOG_FACILITY=local0

# Syslog app identifier
SYSLOG_TAG=ndi-streamer
